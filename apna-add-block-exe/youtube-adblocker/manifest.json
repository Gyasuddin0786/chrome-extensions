{
  "manifest_version": 3,
  "name": "Apna YouTube Ad Blocker Pro",
  "description": "Modern YouTube ad blocker with smart detection",
  "version": "1.0",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://www.youtube.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content/adblock.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html"
  },

  "options_page": "settings/settings.html",

  "icons": {
    "16": "icons/chrome-logo.png",
    "48": "icons/chrome-logo.png",
    "128": "icons/chrome-logo.png"
  }
}